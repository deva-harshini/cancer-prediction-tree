auc = metrics.roc_auc_score(y_test, y_pred_proba)

#create ROC curve
plt.plot(fpr,tpr,label="AUC="+str(auc))
plt.ylabel('Sensitivity')
plt.xlabel('Specificity')
plt.legend(loc=4)
plt.show()

